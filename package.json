{
    "name":  "school-backend",
    "version":  "1.0.0",
    "main":  "server.js",
    "type":  "module",
    "scripts":  {
                    "start":  "node server.js",
                    "dev":  "nodemon server.js",
                    "seed:force":  "node scripts/seed-force.js",
