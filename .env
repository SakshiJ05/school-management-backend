PORT=5000
# Set NODE_ENV=production in live deployments. This DISABLES all dev auth shortcuts
# (DEV_SUPER_ADMIN login, `demo-token` bearer, password-reset OTP echoed in responses)
# and REQUIRES a strong JWT_SECRET (startup fails without one).
NODE_ENV=development
# CHANGE THIS to a long random string before production (openssl rand -hex 32).
JWT_SECRET=edusmart-dev-only-change-me

# MongoDB Atlas (active)
MONGODB_URI=mongodb+srv://ersakshigupta2025:Sakshi%402026@cluster0.2k9qsby.mongodb.net/sms_app?retryWrites=true&w=majority

# Local MongoDB (uncomment instead of Atlas if Mongo is installed locally):
# MONGODB_URI=mongodb://127.0.0.1:27017/school_ms

# --- Local MySQL mirror (XAMPP) ---
# super_admin/admin accounts are dual-written here (Mongo stays primary).
# Start MySQL in XAMPP for this to work. Set SQL_MIRROR=off to disable entirely.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=scholify
SQL_MIRROR=on

# --- Razorpay billing (get keys from https://dashboard.razorpay.com) ---
