PORT=5000

# MongoDB (legacy — existing API)
MONGODB_URI=mongodb://127.0.0.1:27017/school_ms
MONGODB_URI_FALLBACK=
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# MySQL (Scholify v2 redesign)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=scholify
MYSQL_API_PORT=5001
DB_LOGGING=false
SAAS_BASE_DOMAIN=scholify.local

# JWT v2 (access + refresh)
JWT_ACCESS_SECRET=scholify-access-change-me
JWT_REFRESH_SECRET=scholify-refresh-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:4200,http://localhost:5173
USE_SYSTEM_DNS_ONLY=0

# Optional: Stripe for online fees (mock if unset)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: email/SMS providers
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMS_API_KEY=
